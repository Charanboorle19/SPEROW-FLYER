const JourneyNode: React.FC<{
  label: string;
  icon: string;
  index: number;
  delay: number;
  isLast: boolean;
  startOffset: number;
}> = ({label, icon, index, delay, isLast, startOffset}) => {
  const frame = useCurrentFrame();
  const {fps} = useVideoConfig();
  
  const relativeFrame = Math.max(0, frame - startOffset);
  const appearFrame = Math.max(0, relativeFrame - delay);
  
  const nodeScale = spring({
    frame: appearFrame,
    fps,
    config: {damping: 20, stiffness: 100, mass: 0.8},
  });

  const labelOpacity = interpolate(appearFrame, [0, 15], [0, 1], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  const labelY = interpolate(appearFrame, [0, 20], [15, 0], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  const glowOpacity = interpolate(appearFrame, [20, 35, 50], [0, 0.6, 0], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  const iconOpacity = interpolate(appearFrame, [10, 30], [0, 1], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  const iconScale = spring({
    frame: Math.max(0, appearFrame - 15),
    fps,
    config: {damping: 18, stiffness: 90},
  });

  const renderIcon = () => {
    const iconProps = {frame: relativeFrame, appearFrame};
    switch(icon) {
      case 'consultation':
        return <ConsultationIcon {...iconProps} />;
      case 'planning':
        return <PlanningIcon {...iconProps} />;
      case 'procedure':
        return <ProcedureIcon {...iconProps} />;
      case 'recovery':
        return <RecoveryIcon {...iconProps} />;
      case 'followup':
        return <FollowUpIcon {...iconProps} />;
      default:
        return null;
    }
  };

  return (
    <div
      style={{
        ...styles.nodeWrapper,
        top: nodePositions[index],
      }}
    >
      <div
        style={{
          ...styles.iconContainer,
          opacity: iconOpacity,
          transform: `scale(${iconScale})`,
          left: -60,
        }}
      >
        {renderIcon()}
      </div>

      <div style={styles.nodeContainer}>
        <div
          style={{
            ...styles.nodeOuter,
            transform: `scale(${nodeScale})`,
          }}
        >
          <div
            style={{
              ...styles.nodeGlow,
              opacity: glowOpacity,
            }}
          />
          <div style={styles.nodeInner} />
        </div>
      </div>

      <div
        style={{
          ...styles.labelContainer,
          opacity: labelOpacity,
          transform: `translateY(${labelY}px)`,
        }}
      >
        <div style={styles.labelText}>{label}</div>
        {!isLast && index < 4 && (
          <div
            style={{
              ...styles.labelLine,
              width: `${interpolate(appearFrame, [0, 15], [0, 40], {
                extrapolateLeft: 'clamp',
                extrapolateRight: 'clamp',
              })}px`,
            }}
          />
        )}
      </div>
    </div>
  );
};

