const nodePositions = [80, 205, 330, 455, 580];
const SCENE_1_DURATION = 100; // "SPEROW supports every step" duration
const SCENE_2_START_FRAME = SCENE_1_DURATION + 10;
const SCENE_2_DURATION = 100; // 4-8 seconds
const TIMELINE_START_FRAME = SCENE_2_START_FRAME + SCENE_2_DURATION;

export const PatientJourney: React.FC = () => {
  const frame = useCurrentFrame();

  // Scene 1 fade out (SPEROW supports every step)
  const scene1Opacity = interpolate(frame, [SCENE_1_DURATION - 20, SCENE_1_DURATION], [1, 0], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  // Scene 2 fade out
  const scene2Opacity = interpolate(frame, [SCENE_2_START_FRAME + SCENE_2_DURATION - 20, SCENE_2_START_FRAME + SCENE_2_DURATION], [1, 0], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  // Timeline fade in after Scene 2
  const timelineOpacity = interpolate(frame, [TIMELINE_START_FRAME, TIMELINE_START_FRAME + 15], [0, 1], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  // Timeline fade out after completion
  const timelineFadeOut = interpolate(frame, [TIMELINE_START_FRAME + 170, TIMELINE_START_FRAME + 190], [1, 0], {
    extrapolateLeft: 'clamp',
    extrapolateRight: 'clamp',
  });

  return (
    <AbsoluteFill style={styles.container}>
      <style>
        {`@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap');`}
      </style>

      <Background frame={frame} />
      <Particles frame={frame} />

      {/* Scene 1: SPEROW supports every step */}
      <AbsoluteFill style={{opacity: scene1Opacity}}>
        <Sequence from={0} durationInFrames={SCENE_1_DURATION}>
          <Scene1Message />
        </Sequence>
      </AbsoluteFill>

      {/* Scene 2: Surgeon Hero Message (text only) */}
      <AbsoluteFill style={{opacity: scene2Opacity}}>
        <Sequence from={SCENE_2_START_FRAME} durationInFrames={SCENE_2_DURATION}>
          <SurgeonHeroScene />
        </Sequence>
      </AbsoluteFill>

      {/* Timeline - starts after Scene 2 */}
      <AbsoluteFill style={{...styles.timelineWrapper, opacity: timelineOpacity * timelineFadeOut}}>
        <div
          style={{
            ...styles.timelineContainer,
            opacity: timelineOpacity,
          }}
        >
          <div style={styles.lineContainer}>
            <div style={styles.lineBase} />
            <ProgressLine frame={Math.max(0, frame - TIMELINE_START_FRAME)} />
          </div>

          {journeySteps.map((step, index) => (
            <JourneyNode
              key={step.label}
              label={step.label}
              icon={step.icon}
              index={index}
              delay={step.delay}
              isLast={index === journeySteps.length - 1}
              startOffset={TIMELINE_START_FRAME}
            />
          ))}
        </div>
      </AbsoluteFill>
    </AbsoluteFill>
  );
};

